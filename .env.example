FLASK_ENV=production
ENVIRONMENT=production
SECRET_KEY=

# Banco principal em produção. Use PostgreSQL.
DATABASE_URL=
SQLITE_DB_PATH=entrelinhas.db

# Admin inicial/documentação operacional.
ADMIN_EMAIL=
ADMIN_PASSWORD=

PORT=5000
MAX_CONTENT_LENGTH=5242880
PROFILE_PHOTO_MAX_BYTES=2097152

# Uploads: local apenas para desenvolvimento. Em produção, use cloudinary ou s3.
STORAGE_PROVIDER=local
UPLOAD_FOLDER=static/uploads

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=
AWS_PUBLIC_BASE_URL=

SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME_HOURS=24
