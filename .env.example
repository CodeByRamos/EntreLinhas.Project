FLASK_ENV=development
ENVIRONMENT=development
SECRET_KEY=
APP_BASE_URL=http://127.0.0.1:5000

# Banco
# Desenvolvimento pode deixar vazio para usar SQLite local.
# Producao deve usar PostgreSQL, por exemplo:
# DATABASE_URL=postgresql://usuario:senha@host:5432/entrelinhas
DATABASE_URL=
SQLITE_DB_PATH=entrelinhas.db

# E-mail
# Em desenvolvimento, sem MAIL_SERVER, os links de verificacao/reset aparecem no terminal.
# Em producao, configure SMTP real e deixe MAIL_ALLOW_CONSOLE_FALLBACK=false.
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=
MAIL_ALLOW_CONSOLE_FALLBACK=true

# Admin inicial/documentacao operacional
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_USERNAME=
ADMIN_NICKNAME=Admin EntreLinhas
ADMIN_BIO=

PORT=5000
MAX_CONTENT_LENGTH=5242880
PROFILE_PHOTO_MAX_BYTES=2097152

# Uploads: local apenas para desenvolvimento. Em producao, use cloudinary ou s3.
STORAGE_PROVIDER=local
UPLOAD_FOLDER=static/uploads

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=
AWS_PUBLIC_BASE_URL=

SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME_HOURS=24
