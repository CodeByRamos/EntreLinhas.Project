# ==========================================================================
# EntreLinhas — exemplo de variaveis de ambiente
# Copie para .env (git ignora .env) e preencha. NUNCA versione valores reais.
# ==========================================================================

# --- Ambiente ---
FLASK_ENV=development           # 'production' no deploy
ENVIRONMENT=development          # 'production' no deploy
SECRET_KEY=                      # obrigatorio em producao. Gere: python -c "import secrets;print(secrets.token_hex(32))"
APP_BASE_URL=http://127.0.0.1:5000   # em prod: https://seu-app.onrender.com

# --- Banco de dados ---
# Producao usa PostgreSQL no Supabase. Em desenvolvimento, deixe DATABASE_URL
# VAZIO para cair no SQLite local (entrelinhas.db) — zero config.
#
# Supabase: painel -> Project Settings -> Database -> Connection string.
# Use o "Session pooler" (compativel com IPv4, porta 5432) como DATABASE_URL:
#   postgresql://postgres.<ref>:<SENHA>@aws-0-<regiao>.pooler.supabase.com:5432/postgres
# O app aceita tanto postgres:// quanto postgresql:// (config.py normaliza para
# postgresql+psycopg://) e ja desliga prepared statements (compat. com PgBouncer).
DATABASE_URL=
SQLITE_DB_PATH=entrelinhas.db    # so usado quando DATABASE_URL esta vazio (dev/testes)

# Pool de conexoes (Postgres). Padroes servem para Render single-instance.
PG_POOL_MAX=5
PG_POOL_TIMEOUT=10

# --- E-mail (verificacao de conta + recuperacao de senha) ---
# Em dev, sem MAIL_SERVER os links aparecem no terminal (console fallback).
# Em prod, configure SMTP real e deixe MAIL_ALLOW_CONSOLE_FALLBACK=false.
MAIL_SERVER=                     # ex.: smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=                   # ex.: seu-email@gmail.com
MAIL_PASSWORD=                   # senha de app (NAO a senha normal da conta)
MAIL_DEFAULT_SENDER=             # vazio = usa MAIL_USERNAME
MAIL_ALLOW_CONSOLE_FALLBACK=true # false em producao

# --- Admin inicial (criado no boot se preenchido; ideal para hosts sem shell) ---
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_USERNAME=
ADMIN_NICKNAME=Admin EntreLinhas
ADMIN_BIO=

# --- Uploads / storage de fotos de perfil ---
# 'local' so serve em dev (FS efemero em prod perde as fotos). Em producao use
# 'cloudinary' ou 's3'. O app RECUSA subir em producao com STORAGE_PROVIDER=local.
STORAGE_PROVIDER=local
UPLOAD_FOLDER=static/uploads
PROFILE_PHOTO_MAX_BYTES=2097152
MAX_CONTENT_LENGTH=5242880

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=
AWS_PUBLIC_BASE_URL=

# --- Sessao / cookies ---
SESSION_COOKIE_SECURE=false      # true em producao (HTTPS)
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME_HOURS=24

# --- Rate limiting ---
# memory:// serve em single-instance (Render 1 worker). Em multi-instancia use redis://
RATELIMIT_STORAGE_URI=memory://
RATELIMIT_ENABLED=true

# --- hCaptcha (anti-bot, opcional) ---
# Sem as duas chaves, o captcha e ignorado (no-op) e nao quebra o fluxo.
HCAPTCHA_SITEKEY=
HCAPTCHA_SECRET=

# --- Apoio ao projeto (Pix, tudo opcional) ---
PIX_KEY=
PIX_RECEIVER_NAME=
PIX_CITY=
SUPPORT_RECURRING_URL=
SUPPORT_RECURRING_LABEL=Apoio mensal

# --- SEO (opcional) ---
GOOGLE_SITE_VERIFICATION=

PORT=5000
